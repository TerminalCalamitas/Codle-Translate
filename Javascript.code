// For Loop
for (let i = 0; i < 100; i++) {
  console.log("hello");
}
// If Statement
if (i === 1) {
  print(1);
}
// While Loop
while (i < 1) {
  console.log(i);
  i++;
}
// Integer Variable
let integer = 1;
// Float Variable
let floatingpoint = 1.0;
// String Variable
let string = "string";
// Boolean Variable
let boolean = true;
