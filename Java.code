// For Loop
for (int i = 0; i < 100; i++) {
    System.out.println("hello\n");
}
// If Statement
if (i == 1) {
    System.out.println("%d\n", 1);
}
// While Loop
while (i < 1) {
    System.out.println("%d\n", i);
    i++;
}
// Integer Variable
int integer = 1;
// Float Variable
float floatingpoint = 1.0;
// String Variable
String string = "string";
// Boolean Variable
boolean boolean = true;
