program main
  integer :: i
  integer :: integer_var
  real :: floatingpoint
  logical :: boolean
  character(len=20) :: string
  ! For loop
  do i = 0, 100, 1
    print*, "hello"
  end do
  ! If statement
  if (i == 1) then
    print*, 1
  end if
  ! While loop
  do while (i < 1)
    print*, i
    i = i+1
  end do

  ! Integer Variable
  integer_var = 1
  ! Float Variable
  floatingpoint = 1.0
  ! String Variable
  string = "string"
  ! Boolean Variable
  boolean = .true.

end program
